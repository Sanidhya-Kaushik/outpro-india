# .gitignore

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

# ── Environment files (NEVER commit these) ────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env*.local

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
pnpm-debug.log*

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Uploads / temporary files ─────────────────────────────────────────────────
uploads/
tmp/

# ── Docker ────────────────────────────────────────────────────────────────────
# (compose files are committed; data volumes are not)
docker-data/
